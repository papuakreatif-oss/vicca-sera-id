# ========================================
# Vicca Sera Wedding Landing Page
# Environment Variables — Template
# ========================================
# Copy file ini ke .env.local untuk development
# Di Vercel, set di Project Settings → Environment Variables
# ========================================

# ========================================
# Public (client-exposed)
# ========================================
NEXT_PUBLIC_SITE_URL=https://vicca.id
NEXT_PUBLIC_WA_PHONE=6285244661150
NEXT_PUBLIC_BRAND_NAME=Vicca Sera Wedding Organizer

# ========================================
# Server-only (API routes)
# ========================================

# n8n webhook untuk forward form submissions ke CRM / WA notification
# Buat workflow di n8n.papuakreatif.id atau instance lain
N8N_WEBHOOK_URL=https://n8n.papuakreatif.id/webhook/vicca-inquiry

# Resend (transactional email) untuk konfirmasi ke klien + notif internal
RESEND_API_KEY=re_xxxxxxxxxxxxx
NOTIFY_EMAIL=halo@vicca.id
INTERNAL_EMAIL=kaka.admin@papuakreatif.id

# Optional: Plausible analytics untuk privacy-friendly tracking
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=vicca.id

# Optional: Google Analytics 4 (fallback)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Meta Pixel untuk ads tracking
NEXT_PUBLIC_META_PIXEL_ID=000000000000000
